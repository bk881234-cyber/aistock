{
  "version": 2,
  "buildCommand": "cd client && npm install && npm run build",
  "outputDirectory": "client/dist",
  "installCommand": "cd server && npm install",
  "rewrites": [
    { "source": "/api/cron/:path*", "destination": "/api/cron/:path*" },
    { "source": "/api/:path*",      "destination": "/api/server.js"     },
    { "source": "/:path*",          "destination": "/index.html"        }
  ],
  "crons": [
    { "path": "/api/cron/market",  "schedule": "0 0 * * *" },
    { "path": "/api/cron/weather", "schedule": "0 1 * * *" },
    { "path": "/api/cron/alerts",  "schedule": "0 2 * * *" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
